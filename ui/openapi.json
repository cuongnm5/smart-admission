            },
            "type": "array",
            "title": "Transcript"
          }
        },
        "type": "object",
        "title": "AcademicProfile"
      },
      "AwardRecord": {
        "properties": {
          "award_name": {
            "type": "string",
            "title": "Award Name"
          },
          "organizer": {
            "type": "string",
            "title": "Organizer"
          },
          "level": {
            "type": "string",
            "title": "Level"
          },
          "year": {
            "type": "integer",
            "minimum": 1900,
            "title": "Year"
          },
          "description": {
            "type": "string",
            "title": "Description"
          }
        },
        "type": "object",
        "required": [
          "award_name",
          "organizer",
          "level",
          "year",
          "description"
