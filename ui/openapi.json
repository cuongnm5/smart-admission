{
  "openapi": "3.1.0",
  "info": {
    "title": "Smart Admission - University Candidate Matching",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/matching/universities": {
      "post": {
        "tags": [
          "matching"
        ],
        "summary": "Match Universities",
        "operationId": "match_universities_v1_matching_universities_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StudentMatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchingResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pipeline/match-and-analyze": {
      "post": {
        "tags": [
          "pipeline"
        ],
        "summary": "Match And Analyze",
        "operationId": "match_and_analyze_v1_pipeline_match_and_analyze_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StudentMatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UniversityPipelineResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ACTScore": {
        "properties": {
          "composite": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 36,
                "minimum": 0
              },
              {
                "type": "null"
              }
            ],
            "title": "Composite"
          },
          "sections": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Sections"
          }
        },
        "type": "object",
        "title": "ACTScore"
      },
      "APIBScore": {
        "properties": {
          "subject": {
            "type": "string",
            "title": "Subject"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "title": "Score"
          }
        },
        "type": "object",
        "required": [
          "subject",
          "score"
        ],
        "title": "APIBScore"
      },
      "AcademicProfile": {
